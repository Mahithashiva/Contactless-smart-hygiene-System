from machine import Pin, ADC, UART
import time
import network
import urequests

# --- Wi-Fi Credentials ---
WIFI_SSID = "YourWiFiName"
WIFI_PASS = "YourWiFiPassword"

# --- ThingSpeak API ---
THINGSPEAK_API_KEY = "YOUR_THINGSPEAK_WRITE_API_KEY"
THINGSPEAK_URL = "https://api.thingspeak.com/update?api_key=" + THINGSPEAK_API_KEY

# --- Adafruit IO API ---
ADAFRUIT_IO_USERNAME = "YourAdafruitUsername"
ADAFRUIT_IO_KEY = "YourAdafruitKey"
ADAFRUIT_IO_URL = "https://io.adafruit.com/api/v2/" + ADAFRUIT_IO_USERNAME + "/feeds/"

# --- Sensor Pins ---
ir_sensor = Pin(2, Pin.IN)
ldr_sensor = ADC(Pin(26))
ultrasonic_trigger = Pin(3, Pin.OUT)
ultrasonic_echo = Pin(4, Pin.IN)
water_level = ADC(Pin(27))

# --- Output Pins ---
tap = Pin(5, Pin.OUT)
light = Pin(6, Pin.OUT)
motor = Pin(7, Pin.OUT)
pump = Pin(8, Pin.OUT)

# --- Connect to Wi-Fi ---
def connect_wifi():
    wlan = network.WLAN(network.STA_IF)
    wlan.active(True)
    wlan.connect(WIFI_SSID, WIFI_PASS)
    while not wlan.isconnected():
        print("Connecting to Wi-Fi...")
        time.sleep(1)
    print("Connected:", wlan.ifconfig())

# --- Ultrasonic Distance ---
def get_distance():
    ultrasonic_trigger.low()
    time.sleep_us(2)
    ultrasonic_trigger.high()
    time.sleep_us(10)
    ultrasonic_trigger.low()
    while ultrasonic_echo.value() == 0:
        start = time.ticks_us()
    while ultrasonic_echo.value() == 1:
        end = time.ticks_us()
    duration = end - start
    distance = (duration * 0.0343) / 2
    return distance

# --- Send Data to ThingSpeak ---
def send_to_thingspeak(ir, ldr, dist, water):
    url = THINGSPEAK_URL + "&field1={}&field2={}&field3={}&field4={}".format(ir, ldr, dist, water)
    response = urequests.get(url)
    response.close()
    print("Data sent to ThingSpeak")

# --- Send Data to Adafruit IO ---
def send_to_adafruit(feed, value):
    url = ADAFRUIT_IO_URL + feed + "/data"
    headers = {"X-AIO-Key": ADAFRUIT_IO_KEY, "Content-Type": "application/json"}
    data = '{"value":' + str(value) + '}'
    response = urequests.post(url, headers=headers, data=data)
    response.close()
    print("Data sent to Adafruit IO:", feed)

# --- Main Program ---
connect_wifi()

while True:
    ir_value = ir_sensor.value()
    ldr_value = ldr_sensor.read_u16()
    water_value = water_level.read_u16()
    distance = get_distance()

    # --- Control Logic ---
    tap.value(ir_value)
    light.value(ldr_value < 30000)
    motor.value(distance < 10)
    pump.value(water_value < 20000)

    # --- Send Data to Cloud ---
    send_to_thingspeak(ir_value, ldr_value, distance, water_value)
    send_to_adafruit("ir-sensor", ir_value)
    send_to_adafruit("ldr-sensor", ldr_value)
    send_to_adafruit("ultrasonic", distance)
    send_to_adafruit("water-level", water_value)

    print("IR:", ir_value, "LDR:", ldr_value, "Distance:", distance, "Water:", water_value)
    time.sleep(15)  # ThingSpeak minimum delay
